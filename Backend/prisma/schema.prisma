// Prisma Schema for Azure SQL Database (Backend)
// This is the production cloud database schema
// Driver adapters are now stable in Prisma 7 (no preview feature needed)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

// Patient model with sync tracking
model Patient {
  id        Int       @id @default(autoincrement())
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  age       Int
  gender    String
  phone     String
  uhid      String?   @unique
  
  // Timestamps for sync
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  
  // Relations
  invoices  Invoice[]
  
  @@map("patients")
}

// Invoice model with sync tracking
model Invoice {
  id             Int       @id @default(autoincrement())
  invoiceNumber  String    @map("invoice_number")
  patientId      Int       @map("patient_id")
  date           DateTime
  diagnosis      String    @default("")
  notes          String    @default("")
  paymentMethod  String    @default("Cash") @map("payment_method")
  TransactionId  String?   @map("transaction_id")
  total          Float
  discount       Float     @default(0) @map("discount")
  discountType   String    @default("amount") @map("discount_type")
  paymentStatus  String    @default("unpaid") @map("payment_status")
  amountPaid     Float     @default(0) @map("amount_paid")
  
  // Timestamps for sync
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  
  // Relations
  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatments     Treatment[]
  
  // Unique constraint: Each patient can only have one invoice with the same number
  @@unique([patientId, invoiceNumber])
  @@map("invoices")
  @@index([patientId])
}

// Treatment model with sync tracking
model Treatment {
  id         Int       @id @default(autoincrement())
  invoiceId  Int       @map("invoice_id")
  name       String
  duration   String    @default("")
  sessions   Int
  startDate  DateTime  @map("start_date")
  endDate    DateTime  @map("end_date")
  amount     Float
  
  // Timestamps for sync
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  
  // Relations
  invoice    Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  @@map("treatments")
  @@index([invoiceId])
}

// Treatment presets for autocomplete
model TreatmentPreset {
  id               Int      @id @default(autoincrement())
  name             String
  defaultSessions  Int      @map("default_sessions")
  pricePerSession  Float    @map("price_per_session")
  
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  @@map("treatment_presets")
}

// Diagnosis presets for autocomplete suggestions
model DiagnosisPreset {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  frequency Int      @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("diagnosis_presets")
}

// Diagnosis shortcuts — expand short texts to full diagnosis names
model DiagnosisShortcut {
  id       Int    @id @default(autoincrement())
  shortcut String @unique
  expands  String

  @@map("diagnosis_shortcuts")
}
