# Azure Backend URL (deployed App Service)
# Update this after deploying to Azure
AZURE_BACKEND_URL=https://your-app-name.azurewebsites.net

# For local development/testing with local backend
# AZURE_BACKEND_URL=http://localhost:3000

# API Key for backend authentication (must match backend API_KEY)
BACKEND_API_KEY=your-secret-api-key
