# Azure Backend URL for sync
# Dev: switch to http://localhost:3000 when running backend locally
AZURE_BACKEND_URL=https://shree-ram-physio-backend.azurewebsites.net
# AZURE_BACKEND_URL=http://localhost:3000

# Prisma Database URL (SQLite - managed automatically by Electron)
DATABASE_URL="file:./dev.db"

# Error Display Settings - Reduce verbosity
NODE_OPTIONS=--no-warnings
FORCE_COLOR=1
VITE_LOG_LEVEL=warn
ERROR_STACK_TRACE_LIMIT=3

# API Key for backend authentication (must match backend API_KEY)
BACKEND_API_KEY=134a56b2cc6b4aab2bdf0b2361b7b5d5428c12bc31a146752f6bf5810b59b2c3